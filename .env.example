**Artifact 20 → .env.example**

```env
# ==================== Required ====================
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_channel_or_group_chat_id
TELEGRAM_ADMIN_ID=your_personal_telegram_user_id_number

# ==================== Binance (Optional for Testnet) ====================
BINANCE_API_KEY=
BINANCE_API_SECRET=
USE_TESTNET=true

# ==================== Tuning (Safe defaults already set) ====================
MAX_RISK_PER_TRADE=0.005
DAILY_LOSS_LIMIT_PCT=2.0
WEEKLY_LOSS_LIMIT_PCT=5.0
MIN_RR=2.0
SCAN_INTERVAL_MINUTES=5
ENABLE_SAFE_MODE=true

# DB and logs paths are auto-managed